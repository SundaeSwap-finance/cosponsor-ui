    "build": "bun vite build && bun scripts/interpolate-index.mjs",
    "dev": "bun vite dev",
    "dev:preview": "COSPONSOR_APP_ENV=preview bun dev",
    "preview": "bun vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "prettier --write ."
